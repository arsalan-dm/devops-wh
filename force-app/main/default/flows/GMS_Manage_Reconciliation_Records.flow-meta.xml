    <description>Record triggered flow to enable reconciliation records to be updated and a new date assigned, and for a new reconciliation record to be created</description>
    <environments>Default</environments>
    <formulas>
        <name>flaFirstDateofNextQuarter</name>
        <dataType>Date</dataType>
        <expression>DATE(YEAR(TODAY()), MONTH(TODAY()) + 3, 1)</expression>
    </formulas>
    <formulas>
        <name>flaLastDateofNextQuarter</name>
        <dataType>Date</dataType>
        <expression>DATE(
  YEAR({!$Record.Reconciliation_Period_End__c}) + FLOOR((MONTH({!$Record.Reconciliation_Period_End__c}) + 4 - 1) / 12),
  MOD(MONTH({!$Record.Reconciliation_Period_End__c}) + 4 - 1, 12) + 1,
  1
) - 1</expression>
    </formulas>
    <formulas>
        <name>flaScheduledDate</name>
        <dataType>Date</dataType>
        <expression>DATE(YEAR(TODAY()), MONTH(TODAY()) + 2, 3)</expression>
    </formulas>
