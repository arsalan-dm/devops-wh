    <recordCreates>
        <name>Create_FENC_Assessment</name>
        <label>Create FENC Assessment</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>FENC_Date_Started__c</field>
            <value>
                <elementReference>fla_StartNextMonth</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Sample_Status__c</field>
