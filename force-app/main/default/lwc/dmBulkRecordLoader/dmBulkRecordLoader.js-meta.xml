<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>DM Bulk Record Loader</masterLabel>
    <description>Paste Excel tab-delimited data and generate record payload for Flow</description>
    <targets>
        <target>lightning__FlowScreen</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__FlowScreen">
            <property name="objectApiName" type="String" label="Object API Name"/>
            <property name="tabDelimitedText" type="String" label="Tab-Delimited Text"/>
            <property name="fieldNames" type="String[]" label="Field API Names"/>
            <property name="hasHeaderRow" type="Boolean" label="First row is a header"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>