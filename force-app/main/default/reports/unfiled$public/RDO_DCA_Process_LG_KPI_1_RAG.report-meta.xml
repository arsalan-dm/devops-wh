        TEXT(ROUND(((FundingAwardForecast__c.No_of_Homes_Validated__c - FK_FundingAwardActual__c.No_of_Homes_Validated__c) / FundingAwardForecast__c.No_of_Homes_Validated__c) * 100, 1)) &amp; &quot;% variance - &quot; &amp;
        IF(
            FK_FundingAwardActual__c.No_of_Homes_Validated__c &gt;= FundingAwardForecast__c.No_of_Homes_Validated__c, 
            &quot;Green&quot;,
                IF(
                    (FundingAwardForecast__c.No_of_Homes_Validated__c - FK_FundingAwardActual__c.No_of_Homes_Validated__c) / FundingAwardForecast__c.No_of_Homes_Validated__c &lt;= 0.1,
