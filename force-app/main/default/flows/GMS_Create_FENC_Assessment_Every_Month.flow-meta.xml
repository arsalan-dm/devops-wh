<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Is_Today_The_First_Of_The_Month</name>
        <label>Is Today The First Of The Month</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Today Is Not The First</defaultConnectorLabel>
        <rules>
            <name>Today_Is_The_First</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>fla_isTodayTheFirst</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_FENC_Assessment</targetReference>
            </connector>
            <label>Today Is The First</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>fla_isTodayTheFirst</name>
        <dataType>Boolean</dataType>
        <expression>IF(
    DAY(
        TODAY()
    ) = 1, 
    true, 
    false
)</expression>
    </formulas>
    <formulas>
        <name>fla_StartNextMonth</name>
        <dataType>Date</dataType>
        <expression>DATE(YEAR(ADDMONTHS(TODAY(), 1)), MONTH(ADDMONTHS(TODAY(), 1)), 1)</expression>
    </formulas>
    <interviewLabel>GMS - Create FENC Assessment Every Month {!$Flow.CurrentDateTime}</interviewLabel>
    <label>GMS - Create FENC Assessment Every Month</label>
