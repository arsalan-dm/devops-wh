<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>63.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>(DM) Flow Stage Navigation</masterLabel>
    <description>Custom Interactive Flow Stage Navigation</description>
    <targets>
        <target>lightning__FlowScreen</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__FlowScreen">
            <property name="currentStage"
                type="String"
                label="Current Stage"
                description="The current stage the flow is on"
                role='inputOnly'/>
            <property name="stages"
                type="String"
                label="Stages"
                description="A comma delimited list of the stage names"
                role='inputOnly'/>
            <property name="displayType"
                type="String"
                label="Display Type"
                description="Options are base and path, defaults to base"
                default='base'
                role='inputOnly'/>
            <property name='interactable'
                type="String"
                label="Interactable type"
                description="options are: none, all, previousOnly"
                role='inputOnly'
                />
            <property name="clickedStage"
                type="String"
                label="Stage Clicked"
                role= 'outputOnly'/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>