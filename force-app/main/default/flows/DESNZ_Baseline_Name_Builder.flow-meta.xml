<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Builds correct name for baseline records by concatenating the Funding Scheme Acronym, Funding Award Acronym, and Baseline Autonumber to create the baseline name.</description>
    <environments>Default</environments>
    <formulas>
        <name>flaBaselineName</name>
        <dataType>String</dataType>
        <expression>{!$Record.Funding_Award__r.FundingOpportunity.Funding_Scheme_Acronym__c}+&quot;-&quot;+{!$Record.Funding_Award__r.Funding_Award_Acronym__c}+&quot;-&quot;+{!$Record.Baseline_Autonumber__c}</expression>
    </formulas>
    <interviewLabel>DESNZ - Baseline Name Builder {!$Flow.CurrentDateTime}</interviewLabel>
    <label>DESNZ - Baseline Name Builder</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_Baseline_Name</name>
        <label>Update Baseline Name</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <inputAssignments>
            <field>Name</field>
            <value>
                <elementReference>flaBaselineName</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Baseline_Name</targetReference>
        </connector>
        <object>FundingBaseline__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
