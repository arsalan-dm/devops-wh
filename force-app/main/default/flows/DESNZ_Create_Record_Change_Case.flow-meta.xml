    <decisions>
        <name>Does_Delivery_Partner_Exist</name>
        <label>Does Delivery Partner Exist</label>
        <locationX>314</locationX>
        <locationY>566</locationY>
        <defaultConnector>
            <targetReference>Assign_Funding_Award_Owner</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Does not Exist</defaultConnectorLabel>
        <rules>
            <name>Exists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Funding_Award_Participant_PSO.ParticipantId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_PSO</targetReference>
            </connector>
            <label>Exists</label>
        </rules>
    </decisions>
    <decisions>
        <name>Type_of_Record_Change</name>
        <label>Type of Record Change</label>
        <locationX>314</locationX>
        <locationY>1190</locationY>
        <defaultConnector>
            <targetReference>Record_Change_Case</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_property</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Funding_Property.Name</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>PTY</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Record_Change_Type</targetReference>
            </connector>
            <label>Is property</label>
        </rules>
        <rules>
            <name>Is_Measure</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Property_Measure.Name</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>PRM</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Record_Change_Type_Measure</targetReference>
            </connector>
            <label>Is Measure</label>
        </rules>
    </decisions>
