        </value>
    </customProperties>
    <decisions>
        <name>Check_Adjustment_Direction_LG</name>
        <label>Check Adjustment Direction LG</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assign_SHF_Outbound_Text</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>DESNZ &gt; GR</defaultConnectorLabel>
        <rules>
            <name>IS_GR_DESNZ</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Adjustment_Record.Adjustment_Direction__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>GR to DESNZ</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_SHF_Inbound_Text</targetReference>
            </connector>
            <label>IS GR &gt; DESNZ</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Adjustment_Status</name>
        <label>Check Adjustment Status</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assign_LG_Standard_Text</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>is all other statuses</defaultConnectorLabel>
        <rules>
            <name>Is_Reviewl</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Adjustment_Record.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Review</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_GR_Input_Figure</targetReference>
            </connector>
            <label>Is Review</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_GR_Input_Figure</name>
        <label>Check GR Input Figure</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assign_DP_Proposal</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No GR Input Value</defaultConnectorLabel>
        <rules>
            <name>Has_GR_Input_Value</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Adjustment_Record.Grant_Recipient_Proposed_Amount__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>CAdjustment_Screen</targetReference>
            </connector>
            <label>Has GR Input Value</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_if_Adjustment_to_display</name>
        <label>Check if Adjustment to display</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>No_Adjustment_Screen</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Has No Adjustment</defaultConnectorLabel>
        <rules>
            <name>Has_Adjustment</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Adjustment_Record</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_Scheme_Type</targetReference>
            </connector>
            <label>Has Adjustment</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Input_Variables</name>
        <label>Check Input Variables</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Run_User_Award_Retrieve</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Is User Variable</defaultConnectorLabel>
        <rules>
            <name>Is_Input_Variable</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>recordId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Adjustment_Record</targetReference>
            </connector>
            <label>Is Input Variable</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Scheme_Type</name>
        <label>Check Scheme Type</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Check_Adjustment_Direction_LG</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Is SHF</defaultConnectorLabel>
        <rules>
            <name>Is_LG</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_Scheme_Type</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Local Grant</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_Adjustment_Status</targetReference>
            </connector>
            <label>Is LG</label>
        </rules>
    </decisions>
    <description>Screen flow to inform GR that an adjustment has been created against the award.</description>
    <environments>Default</environments>
    <interviewLabel>GMS - GR Clawback Display {!$Flow.CurrentDateTime}</interviewLabel>
    <isAdditionalPermissionRequiredToRun>true</isAdditionalPermissionRequiredToRun>
    <label>GMS - GR Clawback Display</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>Flow</processType>
    <recordLookups>
        <name>Get_Adjustment_Record</name>
        <label>Get Adjustment Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Assign_Scheme_Type</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Funding_Award__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </filters>
        <filters>
            <field>Status__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Proposal</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Funding_Adjustment__c</object>
        <sortField>Date_Raised__c</sortField>
        <sortOrder>Desc</sortOrder>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_Adjustment_Record</name>
        <label>Update Adjustment Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputReference>Get_Adjustment_Record</inputReference>
    </recordUpdates>
    <runInMode>SystemModeWithoutSharing</runInMode>
