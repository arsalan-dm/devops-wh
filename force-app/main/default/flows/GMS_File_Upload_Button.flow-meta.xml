    <assignments>
        <name>Assign_File_Upload_URL</name>
        <label>Assign File Upload URL</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_File_Upload_URL</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>file-upload?Id=</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_File_Upload_URL</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>var_Parent_Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_File_Upload_URL</assignToReference>
            <operator>Add</operator>
