    <assignments>
        <name>Assign_to_single_variable</name>
        <label>Assign to single variable</label>
        <locationX>264</locationX>
        <locationY>539</locationY>
        <assignmentItems>
            <assignToReference>ActiveBatchIDs</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Loop_through_all_Batches.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_through_all_Batches</targetReference>
        </connector>
