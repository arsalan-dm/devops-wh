<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>PC_No_Homes_which_will_not_reach_EPC_C__c</fullName>
    <formula>IF(
    OR(
        ISBLANK(No_of_Homes_which_will_not_reach_EPC_C__c),
        No_of_Homes_which_will_not_reach_EPC_C__c = 0
    ),
    0,
    Homes_post_installation_SAP_68_or_under__c / No_of_Homes_which_will_not_reach_EPC_C__c
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>% No Homes which will not reach EPC C</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
