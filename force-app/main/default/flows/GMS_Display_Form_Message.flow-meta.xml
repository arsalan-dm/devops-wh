        <label>Assign Award Id from User</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>recordId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Run_User_Award_Retrieve.recordId</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Get_Award</targetReference>
        </connector>
    </assignments>
    <customProperties>
        <name>ScreenProgressIndicator</name>
        <value>
            <stringValue>{&quot;location&quot;:&quot;top&quot;,&quot;type&quot;:&quot;simple&quot;}</stringValue>
        </value>
    </customProperties>
    <decisions>
        <name>Award_Record_found_choice</name>
        <label>Award Record Found Choice</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Blank_Screen</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Award Found</defaultConnectorLabel>
        <rules>
            <name>Is_Award_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Award</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_Not_Submitted_or_Revision_Requested_Check</targetReference>
            </connector>
            <label>Is Award Found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Input_Variable</name>
        <label>Check Input Variable</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Run_User_Award_Retrieve</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_Award_Record_Id</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>recordId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Award</targetReference>
            </connector>
            <label>Is Award Record Id</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Not_Submitted_or_Revision_Requested_Check</name>
        <label>Is Not Submitted or Revision Requested Check</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Blank_Screen</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Don&apos;t Display Message</defaultConnectorLabel>
        <rules>
            <name>Display_Message</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Get_Award.Funding_Self_Evaluation__r.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Draft</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Award.Funding_Self_Evaluation__r.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Revision Requested</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Award.Funding_Self_Evaluation__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Display_A1_Form_Message</targetReference>
            </connector>
            <label>Display Message</label>
        </rules>
    </decisions>
