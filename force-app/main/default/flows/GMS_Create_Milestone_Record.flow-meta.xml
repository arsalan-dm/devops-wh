        </defaultConnector>
        <defaultConnectorLabel>No TM Score Found</defaultConnectorLabel>
        <rules>
            <name>Is_68_and_Below_Post</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Property_Detail_Records.TM_Post_Installation_SAP_Score_Max__c</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>68.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_No_of_Homes_which_will_not_reach_EPC_C</targetReference>
            </connector>
            <label>Is 68 and Below</label>
        </rules>
        <rules>
