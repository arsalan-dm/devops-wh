<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>A_A__c</fullName>
    <formula>IF(ISNULL(Grant_Capital_Spend__c)  || Grant_Capital_Spend__c = 0,0, (Grant_Admin_Spend__c +  Grant_Ancillary_Spend__c) /  Grant_Capital_Spend__c)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>(Grant Admin Spend + Grant Ancillary Spend) / Grant Capital Spend

Unless Grant Capital Spend is 0 then it gives 0</inlineHelpText>
    <label>A&amp;A %</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
