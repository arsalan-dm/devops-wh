    <decisions>
        <name>Phase_Tracker_Record_Type</name>
        <label>Phase Tracker Record Type?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>X1_Total_Project_Baseline</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Phase_Tracker_Record.RecordType.Name</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Total</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Copy_5_of_Included_Baselines</targetReference>
            </connector>
            <label>1. Total Project Baseline</label>
        </rules>
        <rules>
            <name>X2_Cumulative_Completed_Phases</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Phase_Tracker_Record.RecordType.Name</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Completed</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Completed_Phase_Baselines</targetReference>
            </connector>
            <label>2. Cumulative Completed Phases</label>
        </rules>
        <rules>
            <name>X3_Cumulative_Including_Approved_Phases</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Phase_Tracker_Record.RecordType.Name</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Approved</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Completed_Approved_Phase_Baselines</targetReference>
            </connector>
            <label>3. Cumulative Including Approved Phases</label>
        </rules>
        <rules>
            <name>X4_Cumulative_Including_Submitted_Phases</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Phase_Tracker_Record.RecordType.Name</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Including Submitted</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Completed_Approved_Submitted_Phase_Baselines</targetReference>
            </connector>
            <label>4. Cumulative Including Submitted Phases</label>
        </rules>
        <rules>
            <name>X5_Remaining_In_Project</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Phase_Tracker_Record.RecordType.Name</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Remaining</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Copy_6_of_Included_Baselines</targetReference>
            </connector>
            <label>5. Remaining In Project</label>
        </rules>
        <rules>
            <name>X6_Submitted_Phase_Requests</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Phase_Tracker_Record.RecordType.Name</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Most Recent Submitted Phase Request</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Phase_Request_Record_Type</targetReference>
            </connector>
            <label>6. Submitted Phase Requests</label>
        </rules>
    </decisions>
