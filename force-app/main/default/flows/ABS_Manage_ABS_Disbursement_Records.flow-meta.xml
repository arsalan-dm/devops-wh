    <description>Self Perpetuating Time paused Flow that automatically creates next disbursement record in the sequence. Checks if April has been pre-created and if it has, updates existing record</description>
    <environments>Default</environments>
    <formulas>
        <name>flaFirstDateofNextMonth</name>
        <dataType>Date</dataType>
        <expression>DATE(
    YEAR(ADDMONTHS(TODAY(), 1)),
    MONTH(ADDMONTHS(TODAY(), 1)),
    1
)</expression>
    </formulas>
    <formulas>
        <name>flaIsMarch</name>
        <dataType>Boolean</dataType>
        <expression>MONTH({!$Record.Payment_Period_Start__c}) = 3</expression>
    </formulas>
    <formulas>
        <name>flaLastDateofNextMonth</name>
        <dataType>Date</dataType>
        <expression>DATE(
    YEAR(ADDMONTHS(TODAY(), 2)),
    MONTH(ADDMONTHS(TODAY(), 2)),
    1
) - 1</expression>
    </formulas>
    <formulas>
        <name>flaScheduledDate</name>
        <dataType>Date</dataType>
        <expression>DATE(
    YEAR(ADDMONTHS(TODAY(), 2)),
    MONTH(ADDMONTHS(TODAY(), 2)),
    8
)</expression>
    </formulas>
