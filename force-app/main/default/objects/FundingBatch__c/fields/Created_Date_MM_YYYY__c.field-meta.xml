<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Created_Date_MM_YYYY__c</fullName>
    <description>Converts the &quot;Created Date&quot; Date/Time field to a Month/Year field, for use in flows.</description>
    <externalId>false</externalId>
    <formula>TEXT(MONTH(DATEVALUE( CreatedDate ))) + &quot;/&quot; + TEXT(YEAR(DATEVALUE( CreatedDate )))</formula>
    <label>Created Date (MM/YYYY)</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
