                    <operator>EqualTo</operator>
                    <rightValue>
                        <stringValue>The Lead Applicant is being replaced by an exisiting consortium member and leaving the consortium</stringValue>
                    </rightValue>
                </conditions>
                <conditions>
                    <leftValueReference>varFundingAward.Record_Type_Name__c</leftValueReference>
                    <operator>Contains</operator>
