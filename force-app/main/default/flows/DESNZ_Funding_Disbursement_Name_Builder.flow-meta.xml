    <description>Builds correct name for funding disbursement records based on the funding award acronym</description>
    <environments>Default</environments>
    <formulas>
        <name>flaDisbursementName</name>
        <dataType>String</dataType>
        <expression>{!$Record.FundingAward.Funding_Award_Acronym__c}+&quot;-&quot;+{!$Record.Name}</expression>
    </formulas>
    <interviewLabel>DESNZ - Funding Disbursement Name Builder {!$Flow.CurrentDateTime}</interviewLabel>
