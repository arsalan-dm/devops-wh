    <decisions>
        <name>Check_if_Status_Needs_Updating</name>
        <label>Check if Status Needs Updating</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Update_rcd_Reconciliation</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Leave Status</defaultConnectorLabel>
        <rules>
            <name>Is_Update_Status_to_Submitted</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_IsSubmitted</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Submitted_Status</targetReference>
            </connector>
            <label>Is Update Status to Submitted</label>
        </rules>
    </decisions>
    <description>Auto launched flow to loop through actuals and payment figures and calculate reconciliation totals</description>
    <environments>Default</environments>
    <interviewLabel>GMS - Calculate Reconciliation Totals {!$Flow.CurrentDateTime}</interviewLabel>
    <isAdditionalPermissionRequiredToRun>true</isAdditionalPermissionRequiredToRun>
    <label>GMS - Calculate Reconciliation Totals</label>
    <loops>
        <name>Loop_Actuals</name>
        <label>Loop Actuals</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_Actuals</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Assign_Actual_Figures</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Get_Payments</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <name>Loop_Child_Transaction_Reords</name>
        <label>Loop Child Transaction Reords</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_Child_Transaction_Records</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Assign_rcd_transaction</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Update_Transaction_Records</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <name>Loop_Disbursements</name>
        <label>Loop Disbursements</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_Payments</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Assign_Disbursement_Figures</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Assign_Updated_Reconciliation</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
