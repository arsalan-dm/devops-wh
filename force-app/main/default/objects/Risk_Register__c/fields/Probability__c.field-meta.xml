<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Probability__c</fullName>
    <description>Displays the percentage based on the Likelihood that the risk will occur during the lifetime of the activity</description>
    <externalId>false</externalId>
    <formula>CASE(
     Likelihood__c ,
    &quot;Very Unlikely&quot;, &quot;&lt;10%&quot;,
    &quot;Unlikely&quot;, &quot;10-35%&quot;,
    &quot;Possible&quot;, &quot;35-65%&quot;,
    &quot;Likely&quot;, &quot;65-90%&quot;,
    &quot;Very Likely&quot;, &quot;90%&gt;&quot;,
    &quot;Certain&quot;, &quot;100%&quot;,
&quot; &quot;
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Displays the percentage based on the Likelihood that the risk will occur during the lifetime of the activity</inlineHelpText>
    <label>Probability %</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
