<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Update_Status_to_Materialised</name>
        <label>Update Status to Materialised</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Risk_Status__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Materialised</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>$Record.Materialised_Date__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Flow.CurrentDate</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_Risk_Register</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Update_Status_to_Open</name>
        <label>Update Status to Open</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Risk_Status__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Open</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>$Record.Materialised_Date__c</assignToReference>
            <operator>Assign</operator>
        </assignmentItems>
        <connector>
            <targetReference>Update_Risk_Register</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Update_Type_to_Issue</name>
        <label>Update Type to Issue</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Risk_Type__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Issue</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>$Record.Materialised_Date__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Flow.CurrentDate</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_Risk_Register</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Update_Type_to_Open</name>
        <label>Update Type to Open</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Risk_Type__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Threat</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>$Record.Materialised_Date__c</assignToReference>
            <operator>Assign</operator>
        </assignmentItems>
        <connector>
            <targetReference>Update_Risk_Register</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Check_Change</name>
        <label>Check Change</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Is no change</defaultConnectorLabel>
        <rules>
            <name>Is_change_Threat_Issue</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.Risk_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Threat</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Risk_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Issue</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Status_to_Materialised</targetReference>
            </connector>
            <label>Is change Threat &gt; Issue</label>
        </rules>
        <rules>
            <name>Is_change_Issue_Threat</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.Risk_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Issue</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Risk_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Threat</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Status_to_Open</targetReference>
            </connector>
            <label>Is change Issue &gt; Threat</label>
        </rules>
        <rules>
            <name>Is_change_Open_Materialised</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.Risk_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Open</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Risk_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Materialised</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Type_to_Issue</targetReference>
            </connector>
            <label>Is change Open &gt; Materialised</label>
        </rules>
        <rules>
            <name>Is_change_Materialised_Open</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.Risk_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Materialised</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Risk_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Open</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Type_to_Open</targetReference>
            </connector>
            <label>Is change Materialised &gt; Open</label>
        </rules>
    </decisions>
    <description>Record triggered flow that will automatically change Status to &apos;Materialised&apos; when Type changed to &apos;Issue&apos; and vice versa</description>
    <environments>Default</environments>
    <interviewLabel>GMS - Sync Materialise and Issue {!$Flow.CurrentDateTime}</interviewLabel>
    <label>GMS - Sync Materialise and Issue</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_Risk_Register</name>
        <label>Update Risk Register</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Change</targetReference>
        </connector>
        <filterLogic>or</filterLogic>
        <filters>
            <field>Risk_Status__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Risk_Type__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Risk_Register__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
