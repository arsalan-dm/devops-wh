<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>63.0</apiVersion>
    <isExposed>true</isExposed>
       <masterLabel>(DM) Chart Single Dataset</masterLabel>
    <description>Create JS Charts</description>
    <targets>
        <target>lightning__FlowScreen</target>
     </targets>
     <targetConfigs>
        <targetConfig targets="lightning__FlowScreen">
            <property name="type" type="String" label="Chart Type" description="Type of chart (e.g., bar, line, pie)" default="bar"/>
            <property name="chartData" type="String" label="Chart Data" description="Comma-separated values for the dataset" />
            <property name="backgroundColors" type="String" label="Background Colors" description="Comma-separated colors for the dataset"/>
            <property name="chartLabels" type="String" label="Chart Labels" description="Comma-separated labels for the dataset"/>
            <property name="chartHeight" type="String" label="Chart Height (px)" description="Height of the chart in pixels" default="400"/>
            <property name="borderWidth" type="String" label="Border Width (px)" description="Width of the border in pixels" />
            <property name="borderColor" type="String" label="Border Colour" description="Colour of the border" />
            <property name="borderColour" type="String" label="DO NOT USE" description="DEPRECATED" />
        </targetConfig>
    </targetConfigs>     
</LightningComponentBundle>