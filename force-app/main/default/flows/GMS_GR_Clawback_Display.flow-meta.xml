    <status>Active</status>
    <subflows>
        <name>Run_User_Award_Retrieve</name>
        <label>Run User Award Retrieve</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Adjustment_Record</targetReference>
        </connector>
        <flowName>DESNZ_User_Award_Retrieve</flowName>
        <outputAssignments>
            <assignToReference>recordId</assignToReference>
            <name>recordId</name>
        </outputAssignments>
    </subflows>
    <textTemplates>
        <name>txt_General_Text</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;strong style=&quot;font-size: 22px;&quot;&gt;An Adjustment Process has been instigated against this Award&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 18px;&quot;&gt;Financial Year Reconciliation Outcome: £{!Get_Adjustment_Record.Reconciliation_Amount__c}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 18px;&quot;&gt;Proposed Adjustment Figure: £{!Get_Adjustment_Record.Proposed_Adjustment_Amount__c}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 18px;&quot;&gt;Note: {!Get_Adjustment_Record.Proposed_Adjustment_Commentary__c}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;{!var_Help_Text}&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 18px;&quot;&gt;Final Adjustment Figure: £{!Get_Adjustment_Record.Final_Adjustment_Amount__c}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 18px;&quot;&gt;Note: {!Get_Adjustment_Record.Final_Adjustment_Commentary__c}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 18px;&quot;&gt;Current Outstanding Balance: £{!Get_Adjustment_Record.Outstanding_Adjustment_Balance__c}&lt;/span&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>txt_inbound_Help_Text_SHF</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;strong style=&quot;font-size: 16px;&quot;&gt;The figure stated is the amount which you owe to DESNZ. This is a clawback amount for grant you have drawdown but not completed works for. If you have any questions or would like to appeal, please reach out to your DSM who can support on the appeals process outline in your clawback letter.&lt;/strong&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>txt_Not_Review_LG</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;strong style=&quot;font-size: 16px; background-color: rgb(255, 255, 255);&quot;&gt;The figure stated above is the amount calculated by an end of year reconciliation. If the number is negative it is owed to DESNZ. If positive it is owed by DESNZ. If you have any questions please reach out to your DSM.&lt;/strong&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>txt_Outbound_Help_SHF</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;strong style=&quot;font-size: 16px;&quot;&gt;The figure stated is the amount which DESNZ will make a payment to you. This is an accruals amount for works you have completed and are owed via your grant amount. If you have any questions, please reach out to your DSM.&lt;/strong&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>txt_Proposal_Text</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;strong style=&quot;font-size: 22px;&quot;&gt;An Adjustment Process has been instigated against this Award&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 18px;&quot;&gt;Financial Year Reconciliation Outcome: £{!Get_Adjustment_Record.Reconciliation_Amount__c}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 18px;&quot;&gt;Proposed Adjustment Figure: £{!Get_Adjustment_Record.Proposed_Adjustment_Amount__c}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 18px;&quot;&gt;Note: {!Get_Adjustment_Record.Proposed_Adjustment_Commentary__c}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 16px; background-color: rgb(255, 255, 255);&quot;&gt;The figure stated above is the amount calculated by an end of year reconciliation. If the RECONCILIATION amount is negative it is owed to DESNZ. If positive it is owed by DESNZ. You have an opportunity below to submit a figure that you feel is appropriate &lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 16px; background-color: rgb(255, 255, 255);&quot;&gt;If you have any questions please reach out to your DSM.&lt;/strong&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>txt_Review_LG</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;PLACEHOLDER TEXT&lt;/p&gt;</text>
    </textTemplates>
