<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>(DM) Bulk Record Input</masterLabel>
    <targets>
        <target>lightning__FlowScreen</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__FlowScreen">
            <propertyType name="T" extends="SObject" label="SObject Type" />
            <property name="sobjectType"
                type="String"
                label="SObject API Name"
                role="inputOnly"/>
            <property name="fieldNames"
                type="String[]"
                label="Fields to be loaded"
                description="Leave blank for all fields"
                role="inputOnly"/>
            <property name="buttonLabel"
                type="String"
                label="Button Label"
                description="Text shown on the Generate Records button. Defaults to 'Generate Records'."
                role="inputOnly"/>
            <property name="updatedRecords" 
                type="{T[]}" 
                label="Updated Records"
                role="outputOnly"/>
            <property name="loadSuccessful"
                type="Boolean"
                label="Load Successful"
                role="outputOnly"/>
            <property name="recordCount"
                type="String"
                label="Number of Records Built"
                role="outputOnly"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>