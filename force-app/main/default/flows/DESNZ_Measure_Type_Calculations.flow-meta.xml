    <description>Record-Triggered Flow runs on creation or update of a Batch Measure Spend record with &apos;Approved&apos; status. It retrieves related active batches from the same baseline, calculates totals and averages across matching records, and updates the related Batch Measure Spend records with the results.</description>
    <environments>Default</environments>
    <formulas>
        <name>AverageSpend</name>
        <dataType>Currency</dataType>
        <expression>{!BatchMeasureSpendTotalSpend} / {!BatchMeasureHouseTotal}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>AverageSpendCostCapDifference</name>
        <dataType>Number</dataType>
        <expression>{!AverageSpend} / {!$Record.Measure_Type__r.Average_Price_Limit__c} * 100</expression>
        <scale>2</scale>
    </formulas>
    <interviewLabel>DESNZ - Measure Type Calculations {!$Flow.CurrentDateTime}</interviewLabel>
    <label>DESNZ - Measure Type Calculations</label>
    <loops>
        <name>Loop_through_all_Batches</name>
        <label>Loop through all Batches</label>
        <locationX>176</locationX>
        <locationY>431</locationY>
        <collectionReference>Get_all_Batches_from_the_same_Baseline</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Assign_to_single_variable</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Get_all_other_matching_Batch_Measure_Spends</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <name>Loop_through_batch_measure_spends</name>
        <label>Loop through batch measure spends</label>
        <locationX>176</locationX>
        <locationY>839</locationY>
        <collectionReference>Get_all_other_matching_Batch_Measure_Spends</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Add_to_single_collection</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Update_Batch_Measure_Spend_records</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_all_Batches_from_the_same_Baseline</name>
        <label>Get all Batches from the same Baseline</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop_through_all_Batches</targetReference>
        </connector>
        <filterLogic>1 AND 4 AND (2 OR 3)</filterLogic>
        <filters>
            <field>Active_Baseline__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Batch__r.Active_Baseline__r.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>ABS_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Approved</stringValue>
            </value>
        </filters>
        <filters>
            <field>ABS_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Closed</stringValue>
            </value>
        </filters>
        <filters>
            <field>Version_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Active</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>FundingBatch__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <description>Gets any other Batch Measure Spend record that is related to a Batch record that looks up to the same Baseline and  lookups to the same Measure Type record.</description>
        <name>Get_all_other_matching_Batch_Measure_Spends</name>
        <label>Get all other matching Batch Measure Spends</label>
        <locationX>176</locationX>
        <locationY>731</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop_through_batch_measure_spends</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Measure_Type_Name__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Measure_Type__r.Name</elementReference>
            </value>
        </filters>
        <filters>
            <field>Batch__c</field>
            <operator>In</operator>
            <value>
                <elementReference>ActiveBatchIDs</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>FundingBatchMeasureSpend__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <description>Updates all Batch Measure Spend records with the total Spend summarised from all Batch Measure Spends that lookup to the same Batch and Property Measure Type. Also updates the Average Spend field with a formula output.</description>
        <name>Update_Batch_Measure_Spend_records</name>
        <label>Update Batch Measure Spend records</label>
        <locationX>176</locationX>
        <locationY>1247</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>In</operator>
            <value>
                <elementReference>MeasureSpendIds</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Average_Cost_Cap_Difference__c</field>
            <value>
                <elementReference>AverageSpendCostCapDifference</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Average_Price_Limit__c</field>
            <value>
                <elementReference>$Record.Measure_Type__r.Average_Price_Limit__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Average_Spend__c</field>
            <value>
                <elementReference>AverageSpend</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Total_House_Count_for_Measure_Type__c</field>
            <value>
                <elementReference>BatchMeasureHouseTotal</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Total_spend_for_this_measure_type__c</field>
            <value>
                <elementReference>BatchMeasureSpendTotalSpend</elementReference>
            </value>
        </inputAssignments>
        <object>FundingBatchMeasureSpend__c</object>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_all_Batches_from_the_same_Baseline</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Approved</stringValue>
            </value>
        </filters>
        <object>FundingBatchMeasureSpend__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
