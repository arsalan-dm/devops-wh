    <decisions>
        <description>Any &apos;High Risk Reds&apos; mean the PR is a Red overall.</description>
        <name>Any_High_Risk_Reds</name>
        <label>Any High Risk Reds?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Any_normal_Reds</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No High Risk Reds</defaultConnectorLabel>
        <rules>
            <name>High_Risk_Reds</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Total_High_Risk_Red__c</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Assessment_Matrix_to_Red</targetReference>
            </connector>
            <label>High Risk Reds</label>
        </rules>
    </decisions>
    <decisions>
        <description>More than one &apos;normal&apos; Red in any section is a Red overall.</description>
        <name>Any_normal_Reds</name>
        <label>Any normal Reds?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>More_than_one_Amber_in_any_section</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Normal Reds</defaultConnectorLabel>
        <rules>
            <name>Normal_Reds</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Declarations_Total_Normal_Red__c</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Homes_Costs_Total_Normal_Red__c</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
