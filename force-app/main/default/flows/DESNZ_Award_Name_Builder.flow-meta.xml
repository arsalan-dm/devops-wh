<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Assign_Award_Name</name>
        <label>Assign Award Name</label>
        <locationX>176</locationX>
        <locationY>287</locationY>
        <assignmentItems>
            <assignToReference>$Record.Name</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>flaAwardName</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <description>Builds correct name for the funding award records that concatenates the Funding Scheme Acronym, Awardee&apos;s Name, and the year &apos;2024&apos; to create an award name.</description>
    <environments>Default</environments>
    <formulas>
        <name>flaAwardName</name>
        <dataType>String</dataType>
        <expression>{!$Record.FundingOpportunity.Funding_Scheme_Acronym__c}+&quot;-&quot;+{!$Record.Awardee.Name}+&quot;-2024&quot;</expression>
    </formulas>
    <interviewLabel>DESNZ - Award Name Builder {!$Flow.CurrentDateTime}</interviewLabel>
    <label>DESNZ - Award Name Builder</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Assign_Award_Name</targetReference>
        </connector>
        <object>FundingAward</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
