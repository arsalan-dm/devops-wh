<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Grant_Capital_Total_3_Years_Request__c</fullName>
    <formula>IF(Parent_Change_Control_Tracker__c = &quot;&quot;, 0,
IF(Pending_Change_Control_Request__c = &quot;&quot;,
(  Original_Award_Project_Baseline__r.Baseline_Grant_Capital_Spend__c  -  Grant_Capital_Total_3_Years__c  ) / Original_Award_Project_Baseline__r.Baseline_Grant_Capital_Spend__c * -1,
(Current_Award_Baseline__r.Baseline_Grant_Capital_Spend__c - Grant_Capital_Total_3_Years__c) / Current_Award_Baseline__r.Baseline_Grant_Capital_Spend__c * -1))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Grant Capital Total 3 Years - Request</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
