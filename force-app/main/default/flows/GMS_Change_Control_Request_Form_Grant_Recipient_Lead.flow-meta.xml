            </styleProperties>
            <visibilityRule>
                <conditionLogic>or</conditionLogic>
                <conditions>
                    <leftValueReference>Reason_for_Grant_Recipient_Lead_Change</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <stringValue>The Lead Applicant is being replaced by a new consortium member but remaining in The consortium</stringValue>
                    </rightValue>
                </conditions>
                <conditions>
                    <leftValueReference>Reason_for_Grant_Recipient_Lead_Change</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <stringValue>The Lead Applicant is being replaced by a new consortium member and leaving the consortium</stringValue>
                    </rightValue>
                </conditions>
            </visibilityRule>
