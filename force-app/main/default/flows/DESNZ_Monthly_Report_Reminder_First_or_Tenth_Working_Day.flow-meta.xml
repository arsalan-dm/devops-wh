    <decisions>
        <name>Is_Today_the_First_Working_Day</name>
        <label>Is Today the First or 10th Working Day?</label>
        <locationX>182</locationX>
        <locationY>360</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>today</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Get_10th_Working_Day_of_Month.Scheme_Reporting_Date__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>today</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>First_working_day_of_the_month</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>get_Contacts</targetReference>
            </connector>
            <label>1st or 10th working day of the month</label>
        </rules>
    </decisions>
    <description>Monthly Report Reminder First or Tenth Working Day</description>
    <environments>Default</environments>
    <formulas>
        <name>First_working_day_of_the_month</name>
        <dataType>Date</dataType>
        <expression>IF(
    WEEKDAY(DATE(YEAR(TODAY()), MONTH(TODAY()), 1)) = 7, 
    DATE(YEAR(TODAY()), MONTH(TODAY()), 3), 
    IF(
        WEEKDAY(DATE(YEAR(TODAY()), MONTH(TODAY()), 1)) = 1, 
        DATE(YEAR(TODAY()), MONTH(TODAY()), 2), 
        DATE(YEAR(TODAY()), MONTH(TODAY()), 1)
    )
)</expression>
    </formulas>
    <formulas>
        <name>TenthWorkingDayOfTheMonth</name>
        <dataType>Date</dataType>
        <expression>CASE(
    MOD(WEEKDAY(DATE(YEAR(TODAY()), MONTH(TODAY()), 1)), 7),
    1, DATE(YEAR(TODAY()), MONTH(TODAY()), 10 + 2),
    7, DATE(YEAR(TODAY()), MONTH(TODAY()), 10 + 1),
    DATE(YEAR(TODAY()), MONTH(TODAY()), 10)
) +
CASE(
    MOD(10 + (FLOOR((10 + WEEKDAY(DATE(YEAR(TODAY()), MONTH(TODAY()), 1)) - 1) / 7) * 2), 7),
    6, 2,
    0, 1,
    0
)</expression>
    </formulas>
    <formulas>
        <name>today</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <interviewLabel>DESNZ - Monthly Report Reminder First or Tenth Working Day {!$Flow.CurrentDateTime}</interviewLabel>
