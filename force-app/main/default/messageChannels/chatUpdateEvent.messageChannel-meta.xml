<?xml version="1.0" encoding="UTF-8"?>
<LightningMessageChannel xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>This event is fired from the chat list component when a chat is selected</description>
    <isExposed>true</isExposed>
    <lightningMessageFields>
        <description>Indicates if a chat has been selected or deselected</description>
        <fieldName>eventType</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <description>Indicates the lwc which fired the event, used to handle recursion</description>
        <fieldName>eventSource</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <description>Used to indiacate the chat parent context</description>
        <fieldName>chatParentContextId</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <description>Holds the record name for the parent context</description>
        <fieldName>chatParentContextName</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <description>Holds the Awardee name for the parent context</description>
        <fieldName>chatAwardeeName</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <description>Indicates if the chat is unfollowed</description>
        <fieldName>chatIsUnfollowed</fieldName>
    </lightningMessageFields>
    <masterLabel>ChatUpdateEvent</masterLabel>
</LightningMessageChannel>
