        </assignmentItems>
        <assignmentItems>
            <assignToReference>rcdNewCase.Subject</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Help_or_Support_Summary</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rcdNewCase.Description</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Description</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rcdNewCase.OwnerId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>varCaseOwner</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Create_Support_case</targetReference>
        </connector>
    </assignments>
    <assignments>
