<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Scheduled_Date_MMYYYY__c</fullName>
    <description>Converts the &quot;Scheduled Date&quot; Date/Time field to a Month/Year field, for use in flows.</description>
    <externalId>false</externalId>
    <formula>TEXT(MONTH(DATEVALUE(ScheduledDate ))) + &quot;/&quot; + TEXT(YEAR(DATEVALUE(ScheduledDate)))</formula>
    <label>Scheduled Date (MM/YYYY)</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
