    <description>Portal Screen Flow that handles which screen to pass the user to next when navigating the batch create and edit form</description>
    <environments>Default</environments>
    <formulas>
        <name>flaEndoFFinancialYear</name>
        <dataType>Date</dataType>
        <expression>IF(
    YEAR(TODAY()) = 2025 &amp;&amp; MONTH(TODAY()) &lt;= 3, 
    DATE(2026, 3, 31), 
    IF(
        MONTH(TODAY()) &gt; 3, 
        DATE(YEAR(TODAY()) + 1, 3, 31),  
        DATE(YEAR(TODAY()), 3, 31)
    )
)</expression>
    </formulas>
