<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>PC_No_of_Homes_to_EPC_A_or_B__c</fullName>
    <formula>IF(
    OR(
        ISBLANK(No_of_Homes_to_EPC_A_or_B__c),
        No_of_Homes_to_EPC_A_or_B__c = 0
    ),
    0,
    Homes_post_installation_SAP_81_or_above__c / No_of_Homes_to_EPC_A_or_B__c
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>% No of Homes to EPC A or B</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
