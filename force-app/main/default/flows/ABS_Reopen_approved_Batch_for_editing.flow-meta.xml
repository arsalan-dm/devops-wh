    <decisions>
        <name>Check_Batch_Version_Number</name>
        <label>Check Batch Version Number</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Subsequent_assign_Original_Batch</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Is Subsequent Revisions</defaultConnectorLabel>
        <rules>
            <name>Is_First_Post_Payment_Revision</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Batch.Version_Number__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>First_assign_Original_Batch</targetReference>
            </connector>
            <label>Is First Post-Payment Revision</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Disbursement_Submission_Date</name>
        <label>Check Disbursement Submission Date</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Re_Check_Version_Number</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Reached Disbursement Submission Date</defaultConnectorLabel>
        <rules>
            <name>Not_Reached_Disbursement_Submission_Date</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Get_Batch.Parent_Disbursement__r.Submission_Date__c</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Batch.Parent_Disbursement__r.Submission_Date__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_0_Batch_total_to_carry_forward</targetReference>
            </connector>
            <label>Not Reached Disbursement Submission Date</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_if_Cancelled</name>
        <label>Check if Cancelled</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Run_New_Version_Batch</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Is Continue</defaultConnectorLabel>
        <rules>
            <name>Is_Cancelled</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Confirm_Batch_to_be_reopened</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>chcCancel</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <isGoTo>true</isGoTo>
                <targetReference>Launch_Button_Screen</targetReference>
            </connector>
            <label>Is Cancelled</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Reopen_Batch_Display</name>
        <label>Check Reopen Batch Display</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Launch_Button_Screen</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Is Batch not yet Reopened</defaultConnectorLabel>
        <rules>
            <name>Is_Batch_Reopened</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Batch.Reopen_Batch_Display__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Batch.ABS_Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Approved</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Batch_Reopened_Screen</targetReference>
            </connector>
            <label>Is Batch Reopened</label>
        </rules>
    </decisions>
    <decisions>
        <name>Re_Check_Version_Number</name>
        <label>Re-Check Version Number</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assign_Total_Batches</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Version Number Greater than 1</defaultConnectorLabel>
        <rules>
            <name>Version_Number_is_1</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Batch.Version_Number__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Current_Batch_Only</targetReference>
            </connector>
            <label>Version Number is 1</label>
        </rules>
    </decisions>
