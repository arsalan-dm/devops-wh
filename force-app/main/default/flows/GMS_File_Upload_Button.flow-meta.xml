        <assignmentItems>
            <assignToReference>var_File_Upload_URL</assignToReference>
            <operator>Add</operator>
            <value>
                <stringValue>&amp;sub_category=</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_File_Upload_URL</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>var_Sub_Category_Input</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>File_Upload_Screen</targetReference>
        </connector>
    </assignments>
