    <description>Displays the alert to the GR when the date of the next monthly update is due on the Grant Recipient Portal</description>
    <environments>Default</environments>
    <formulas>
        <name>flaAlert</name>
        <dataType>String</dataType>
        <expression>IF(
    {!Get_Award_Record.Next_Reporting_Date__c} = TODAY(),
    {!flaMonth} &amp; &quot; monthly update is due Today on the &quot; ,
    IF(
        {!Get_Award_Record.Next_Reporting_Date__c} &gt; TODAY(),
        {!flaMonth} &amp; &quot; monthly update is due in &quot; &amp; TEXT({!Get_Award_Record.Next_Reporting_Date__c} - TODAY()) &amp; &quot; days, on the &quot;,
        &quot;is in 0 days&quot;
    )
)</expression>
    </formulas>
    <formulas>
        <name>flaDaysUntilMonthlyReportDate</name>
        <dataType>Number</dataType>
        <expression>IF(
    {!Get_Award_Record.Next_Reporting_Date__c} &gt;= TODAY(),
   {!Get_Award_Record.Next_Reporting_Date__c} - TODAY(),
    0
)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>flaMonth</name>
        <dataType>String</dataType>
        <expression>CASE(
    MONTH({!Get_Award_Record.Next_Reporting_Date__c}),
    1, &quot;January&quot;,
    2, &quot;February&quot;,
    3, &quot;March&quot;,
    4, &quot;April&quot;,
    5, &quot;May&quot;,
    6, &quot;June&quot;,
    7, &quot;July&quot;,
    8, &quot;August&quot;,
    9, &quot;September&quot;,
    10, &quot;October&quot;,
    11, &quot;November&quot;,
    12, &quot;December&quot;,
    &quot;Unknown&quot;
)</expression>
    </formulas>
    <formulas>
        <name>flaToday</name>
        <dataType>String</dataType>
        <expression>IF(
    {!Get_Award_Record.Next_Reporting_Date__c} = TODAY(),
    {!flaMonth} &amp; &quot; monthly update is due Today on the &quot; &amp; TEXT({!Get_Award_Record.Next_Reporting_Date__c})  ,
    IF(
        {!Get_Award_Record.Next_Reporting_Date__c} &gt; TODAY(),
        {!flaMonth} &amp; &quot; monthly update is due on the&quot; &amp; TEXT({!Get_Award_Record.Next_Reporting_Date__c} - TODAY()) &amp; &quot; days on the &quot;,
        &quot;is in 0 days&quot;
    )
)</expression>
    </formulas>
