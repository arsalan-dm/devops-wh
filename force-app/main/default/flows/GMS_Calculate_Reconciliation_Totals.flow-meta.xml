        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_Actuals</name>
        <label>Get Actuals</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop_Actuals</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Funding_Award__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>rcd_Reconciliation.Funding_Award__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>Actuals_Start_Date__c</field>
            <operator>GreaterThanOrEqualTo</operator>
            <value>
                <elementReference>rcd_Reconciliation.Reconciliation_Period_Start__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>Actuals_End_Date__c</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>rcd_Reconciliation.Reconciliation_Period_End__c</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>FundingAwardActual__c</object>
        <sortField>Id</sortField>
        <sortOrder>Asc</sortOrder>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_Child_Transaction_Records</name>
        <label>Get Child Transaction Records</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop_Child_Transaction_Reords</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Funding_Reconciliation__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>rcd_Reconciliation.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Reconciled</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>Funding_Transaction__c</object>
        <sortField>Id</sortField>
        <sortOrder>Asc</sortOrder>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_Payments</name>
        <label>Get Payments</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop_Disbursements</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>FundingAwardId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>rcd_Reconciliation.Funding_Award__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>Submission_Date__c</field>
            <operator>GreaterThanOrEqualTo</operator>
            <value>
                <elementReference>rcd_Reconciliation.Reconciliation_Period_Start__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>Submission_Date__c</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>rcd_Reconciliation.Reconciliation_Period_End__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>Status</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Paid</stringValue>
            </value>
        </filters>
        <filters>
            <field>Payment_Received__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>FundingDisbursement</object>
        <sortField>Id</sortField>
        <sortOrder>Asc</sortOrder>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_rcd_Reconciliation</name>
        <label>Update rcd_Reconciliation</label>
        <locationX>0</locationX>
