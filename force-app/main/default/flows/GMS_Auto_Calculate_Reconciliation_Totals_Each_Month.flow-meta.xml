        <defaultConnector>
            <targetReference>Assign_Disbursement_Figures</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Is Positive</defaultConnectorLabel>
        <rules>
            <name>Not_Positive</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Disbursements.Amount</leftValueReference>
                <operator>LessThan</operator>
