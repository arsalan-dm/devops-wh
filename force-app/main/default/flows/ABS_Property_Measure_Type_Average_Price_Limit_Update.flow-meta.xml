<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>63.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Record Triggered Flow that updates the Batch measure spends which reference a Property Measure Type with the average spend of that Property Measure Type</description>
    <environments>Default</environments>
    <interviewLabel>ABS - Property Measure Type Average Price Limit Update {!$Flow.CurrentDateTime}</interviewLabel>
    <label>ABS - Property Measure Type Average Price Limit Update</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_Batch_Measure_Spends</name>
        <label>Update Batch Measure Spends</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Measure_Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Average_Price_Limit__c</field>
            <value>
                <elementReference>$Record.Average_Price_Limit__c</elementReference>
            </value>
        </inputAssignments>
        <object>FundingBatchMeasureSpend__c</object>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Batch_Measure_Spends</targetReference>
        </connector>
        <object>PropertyMeasureType__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
