    <decisions>
        <name>Check_Award_Record_Type</name>
        <label>Check Award Record Type</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>IS LG</defaultConnectorLabel>
        <rules>
            <name>Is_SHF</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Funding_Award__r.Record_Type_Name__c</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>SHF</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Existing_Milestone_for_Actual</targetReference>
            </connector>
            <label>Is SHF</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Child_Milestone_Measures</name>
        <label>Check Child Milestone Measures</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Delete_Existing_Milestone_for_Actual</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Child Milestone Measures</defaultConnectorLabel>
        <rules>
            <name>Has_Child_Milestone_Measures</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Child_Milestone_Measures</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Delete_Child_Milestone_Measures</targetReference>
            </connector>
            <label>Has Child Milestone Measures</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_if_Milestone_Exists_for_Actual</name>
        <label>Check if Milestone Exists for Actual</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Run_Create_Milestone_Flow</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Milestone Exists for Actual</defaultConnectorLabel>
        <rules>
            <name>Is_Milestone_Exists_for_Actual</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Existing_Milestone_for_Actual</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Child_Milestone_Measures</targetReference>
            </connector>
            <label>Is Milestone Exists for Actual</label>
        </rules>
    </decisions>
