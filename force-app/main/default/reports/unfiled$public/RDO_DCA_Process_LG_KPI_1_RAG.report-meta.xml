        <calculatedFormula>IF(
    ISBLANK(FundingAwardForecast__c.No_of_Homes_Validated__c) || ISBLANK(FK_FundingAwardActual__c.No_of_Homes_Validated__c),
    &quot;Missing Data&quot;,
