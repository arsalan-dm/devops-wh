                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Assessment_Matrix_to_Red1</targetReference>
            </connector>
            <label>Normal Reds</label>
        </rules>
    </decisions>
