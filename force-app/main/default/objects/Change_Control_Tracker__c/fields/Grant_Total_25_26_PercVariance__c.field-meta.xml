(  Original_Award_Project_Baseline__r.Grant_Spend_25_26__c  -  Grant_Total_2526__c ) / Original_Award_Project_Baseline__r.Grant_Spend_25_26__c * -1,
(Current_Award_Baseline__r.Grant_Spend_25_26__c - Grant_Total_2526__c) / Current_Award_Baseline__r.Grant_Spend_25_26__c * -1))</formula>
