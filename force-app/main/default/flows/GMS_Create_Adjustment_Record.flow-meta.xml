    <decisions>
        <name>Check_Adjustment_Direction</name>
        <label>Check Adjustment Direction</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assign_Adjustment_Direction_GR_DESNZ</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Is GR &gt; DESNZ</defaultConnectorLabel>
        <rules>
            <name>Is_DESNZ_GR</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Reconcilliation.Actuals_Payments_Variance__c</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Adjustment_Direction_DESNZ_GR</targetReference>
            </connector>
            <label>Is DESNZ &gt; GR</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Award_Type</name>
        <label>Check Award Type</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Get_Record_Type_SHF</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Is SHF</defaultConnectorLabel>
        <rules>
            <name>is_LG</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Reconcilliation.Funding_Award__r.Record_Type_Name__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Local Grant</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Record_Type_LG</targetReference>
            </connector>
            <label>is LG</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_if_Adjustment_exists</name>
        <label>Check if Adjustment exists</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>FInal_Display_Screen</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Adjustment Exists</defaultConnectorLabel>
        <rules>
            <name>No_Adjustment_Exists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Reconcilliation.Related_Adjustment__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Launch_Screen</targetReference>
            </connector>
            <label>No Adjustment Exists</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Next_FY_Reconciliation_Found</name>
        <label>Check Next FY Reconciliation Found</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>FInal_Display_Screen</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Reconciliation Found</defaultConnectorLabel>
        <rules>
            <name>Is_Reconciliation_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Next_FY_Reconciliation</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Adjustment_to_Reconciliation</targetReference>
            </connector>
            <label>Is Reconciliation Found</label>
        </rules>
    </decisions>
